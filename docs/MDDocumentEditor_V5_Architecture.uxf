*LineState*
--
*Referencia a datos*
+md_line: MDLine  // referencia, no copia
+index: int
--
*Estado de UI*
+selected: bool = False
+active: bool = False
+editing: bool = False
+hotlight: bool = False
+visible: bool = True
+cursor_pos: Tuple[int, int] = (0, 0)
--
*Métodos*
+with_changes(**kwargs): LineState
+get_md_text(): str  // delegado a md_line
+get_line_type(): MD_LINE_TYPE  // delegado
--
*Evento (emitido al cambiar)*
+on_state_changed: EventDispatcher</panel_attributes>

*LineStateEvent*
--
+index: int
+line_state: LineState
+old_state: LineState
+changed_attributes: Set[str]
+event_type: str  // 'changed', 'added', 'removed'
--
+is_activation_change(): bool
+is_selection_change(): bool
+is_content_change(): bool</panel_attributes>
